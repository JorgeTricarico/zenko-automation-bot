// Schema para Masajes Damián
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Appointment {
  id          String   @id
  clientName  String
  clientPhone String
  service     String   // ej: "Masaje Deportivo", "Masaje Relajante"
  duration    Int      // minutos
  date        String
  time        String
  status      String   @default("pendiente") // pendiente | confirmado | cancelado | completado
  price       Float
  notes       String?
  createdAt   DateTime @default(now())
}

model FinancialEntry {
  id          String   @id
  date        String
  type        String   // "income" or "expense"
  category    String
  amount      Float
  description String
}
